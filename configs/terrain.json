{
  "panel_based": true,
  "note": "Panel dimensions computed from viewport at runtime. See panel-grid.ts.",
  "biome_terrain_rules": {
    "grassland_clearing": { "primary": "grass", "water_coverage": 0.15, "mud_coverage": 0.05 },
    "muddy_forest": { "primary": "grass", "mud_coverage": 0.3, "tree_density": 0.2 },
    "rocky_marsh": { "primary": "grass", "rock_coverage": 0.2, "high_ground_coverage": 0.15, "water_coverage": 0.1 },
    "flooded_swamp": { "primary": "shallows", "water_coverage": 0.4, "mud_coverage": 0.15 },
    "stone_quarry": { "primary": "grass", "rock_coverage": 0.35, "narrow_paths": true },
    "dense_thicket": { "primary": "grass", "tree_density": 0.35, "vision_blocking": true }
  },
  "cluster_tuning": {
    "max_clusters": 4,
    "coverage_cluster_scale": 10,
    "base_radius_offset": 3,
    "coverage_radius_scale": 8,
    "sub_circle_min": 2,
    "sub_circle_max": 4,
    "margin_tiles": 3
  },
  "resource_types": ["fish_node", "rock_deposit", "tree_cluster", "rare_node"],
  "terrain_types": ["grass", "water", "shallows", "mud", "rocks", "high_ground", "thorn_wall"]
}
