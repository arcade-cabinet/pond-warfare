{
  "name": "pond-warfare",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copywasm": "node -e \"const fs=require('fs'),p=require('path');const d=p.join('public','assets');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(require.resolve('sql.js/dist/sql-wasm.wasm'),p.join(d,'sql-wasm.wasm'))\"",
    "dev": "vite",
    "build": "pnpm copywasm && tsc --noEmit && vite build",
    "build:web": "pnpm build",
    "build:android": "pnpm generate:icons && CAPACITOR=true pnpm copywasm && tsc --noEmit && vite build && npx cap sync android && pnpm sync:android-shell",
    "dev:android": "pnpm generate:icons && CAPACITOR=true vite build && npx cap sync android && pnpm sync:android-shell && npx cap open android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "audit:browser-captures": "pnpm exec vitest run --config vitest.browser.config.ts tests/browser/current-flow-captures.test.tsx --maxWorkers=1 --reporter=verbose && node scripts/write-browser-audit-manifest.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "generate:icons": "node scripts/generate-icons.js",
    "sync:android-shell": "node scripts/sync-android-shell.js",
    "verify:release": "bash scripts/verify-release.sh"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@preact/signals": "^2.9.0",
    "animejs": "^4.3.6",
    "bitecs": "^0.4.0",
    "jeep-sqlite": "^2.8.0",
    "pixi.js": "^8.17.1",
    "planck": "^1.4.3",
    "preact": "^10.29.0",
    "tone": "^15.1.22",
    "trystero": "^0.23.0",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@capacitor/cli": "^8.3.0",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/preact": "^3.2.4",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "sql.js": "1.11.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.5"
    }
  }
}
